generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WORKER
  POSTER
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
}

enum JobStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  FCFS_ACCEPTED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  PAID
  VOIDED
  REFUNDED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum IncidentStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum DisputeOutcome {
  WORKER_FAVOR
  POSTER_FAVOR
  SPLIT
  DISMISSED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  passwordHash  String
  role          Role       @default(WORKER)
  status        UserStatus @default(PENDING_VERIFICATION)
  emailVerified DateTime?
  bio           String?
  phone         String?
  location      String?
  avatarUrl     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  postedJobs      Job[]            @relation("PosterJobs")
  applications    Application[]
  sessions        Session[]
  accounts        Account[]
  workerProfile   WorkerProfile?
  posterProfile   PosterProfile?
  ratingsGiven    Rating[]         @relation("RatingFrom")
  ratingsReceived Rating[]         @relation("RatingTo")
  competencyScore CompetencyScore?
  riskScore       RiskScore?
  incidents       SafetyIncident[] @relation("IncidentReporter")
  adminNotes      AdminNote[]
  backgroundCheckFees BackgroundCheckFee[]
  jobCheckIns     JobCheckIn[]       @relation("WorkerCheckIns")
  sentMessages    ChatMessage[]      @relation("MessageSender")
  xpTransactions  XPTransaction[]    @relation("UserXpTransactions")
  userLevel       UserLevel?
}

model WorkerProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  skills                String[]
  availability          String?
  hourlyRate            Float?
  idVerified            Boolean  @default(false)
  backgroundCheckStatus String   @default("PENDING")
  emergencyContact      String?
  emergencyContactPhone String?
  onboardingComplete    Boolean  @default(false)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt             DateTime @updatedAt
}

model PosterProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String?
  bio         String?
  website     String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id           String         @id @default(cuid())
  title        String
  description  String
  category     String
  location     String
  locationLat  Float?
  locationLng  Float?
  payRate      Float
  payUnit      String         @default("hour")
  startDate    DateTime?
  endDate      DateTime?
  status       JobStatus      @default(DRAFT)
  posterId     String
  poster       User           @relation("PosterJobs", fields: [posterId], references: [id])
  applications Application[]
  payment      Payment?
  ratings      Rating[]
  disputes     Dispute[]
  incidents    SafetyIncident[]
  platformFees PlatformFee[]
  jobCheckIns  JobCheckIn[]         @relation("JobCheckIns")
  chatThreads  ChatThread[]
  fcfsMode     Boolean            @default(true)
  fcfsTimeoutMinutes Int?         @default(30)
  fcfsLockedAt DateTime?
  xpTransactions XPTransaction[]   @relation("JobXpTransactions")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Application {
  id        String            @id @default(cuid())
  jobId     String
  workerId  String
  message   String?
  status    ApplicationStatus @default(PENDING)
  acceptedAt DateTime?
  firstCheckInAt DateTime?
  job       Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker    User              @relation(fields: [workerId], references: [id])
  checkIns  JobCheckIn[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([jobId, workerId])
}

model Payment {
  id                      String        @id @default(cuid())
  jobId                   String        @unique
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  amount                  Int
  currency                String        @default("usd")
  status                  PaymentStatus @default(PENDING)
  job                     Job           @relation(fields: [jobId], references: [id])
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model Rating {
  id         String   @id @default(cuid())
  jobId      String
  fromUserId String
  toUserId   String
  score      Int
  comment    String?
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fromUser   User     @relation("RatingFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("RatingTo", fields: [toUserId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([jobId, fromUserId])
}

model CompetencyScore {
  id            String   @id @default(cuid())
  userId        String   @unique
  avgRating     Float    @default(0)
  jobsCompleted Int      @default(0)
  reliabilityPct Float   @default(0)
  overallScore  Float    @default(0)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt     DateTime @updatedAt
}

model SafetyIncident {
  id          String         @id @default(cuid())
  jobId       String
  reporterId  String
  severity    String
  description String
  status      IncidentStatus @default(OPEN)
  resolution  String?
  riskLevel   RiskLevel?
  job         Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reporter    User           @relation("IncidentReporter", fields: [reporterId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model RiskScore {
  id            String    @id @default(cuid())
  userId        String    @unique
  riskLevel     RiskLevel @default(LOW)
  incidentCount Int       @default(0)
  overrideNote  String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt     DateTime  @updatedAt
}

model Dispute {
  id         String          @id @default(cuid())
  jobId      String
  raisedById String
  status     DisputeStatus   @default(OPEN)
  outcome    DisputeOutcome?
  adminNote  String?
  job        Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  note      String
  authorId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum FeeType {
  PLATFORM_SERVICE
  BACKGROUND_CHECK
}

enum AdminConfigKey {
  PLATFORM_FEE_PERCENT
  BACKGROUND_CHECK_FEE_CENTS
}

model PlatformFee {
  id        String   @id @default(cuid())
  jobId     String   @unique
  amount    Int
  type      FeeType  @default(PLATFORM_SERVICE)
  percent   Float    @default(0.10)
  status    PaymentStatus @default(PENDING)
  job       Job      @relation(fields: [jobId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BackgroundCheckFee {
  id        String   @id @default(cuid())
  workerId  String
  amount    Int
  status    PaymentStatus @default(PENDING)
  worker    User     @relation(fields: [workerId], references: [id])
  stripePaymentIntentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminConfig {
  id        String   @id @default(cuid())
  key       AdminConfigKey @unique
  value     String
  updatedAt DateTime @updatedAt
}

model JobCheckIn {
  id         String   @id @default(cuid())
  jobId      String
  workerId   String
  latitude   Float
  longitude  Float
  timestamp  DateTime @default(now())
  verified   Boolean  @default(false)
  distanceM  Float?
  application Application @relation(fields: [applicationId], references: [id])
  applicationId String
  job        Job      @relation("JobCheckIns", fields: [jobId], references: [id], onDelete: Cascade)
  worker     User     @relation("WorkerCheckIns", fields: [workerId], references: [id])
  createdAt  DateTime @default(now())

  @@index([jobId, workerId])
}

enum ChatThreadType {
  PUBLIC_QA
  PRIVATE
}

model ChatThread {
  id           String         @id @default(cuid())
  jobId        String
  threadType   ChatThreadType @default(PUBLIC_QA)
  lastMessageAt DateTime?
  job          Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([jobId, threadType])
}

model ChatMessage {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  content   String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User       @relation("MessageSender", fields: [senderId], references: [id])
  createdAt DateTime   @default(now())

  @@index([threadId])
  @@index([threadId, createdAt])
}

enum XPAction {
  JOB_ACCEPTED
  STAGE_COMPLETED
  QUEST_COMPLETED
  RATING_RECEIVED_5_STAR
  USER_CREATED
}

enum Retailer {
  AMAZON
  HOME_DEPOT
  LOWES
  OTHER
}

model AffiliateLink {
  id          String    @id @default(cuid())
  jobCategory String
  toolName    String
  description String
  affiliateUrl String
  retailer    Retailer  @default(AMAZON)
  imageUrl    String?
  clickCount  Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clicks      AffiliateLinkClick[]

  @@index([jobCategory, isActive])
}

model AffiliateLinkClick {
  id             String   @id @default(cuid())
  affiliateLinkId String
  userId         String?
  ipAddress      String?
  clickedAt      DateTime @default(now())
  affiliateLink  AffiliateLink @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)

  @@index([affiliateLinkId, clickedAt])
}

model XPTransaction {
  id         String   @id @default(cuid())
  userId     String
  jobId      String?
  action     XPAction
  xpAwarded  Int
  createdAt  DateTime @default(now())

  user  User   @relation("UserXpTransactions", fields: [userId], references: [id], onDelete: Cascade)
  job   Job?   @relation("JobXpTransactions", fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action])
}

model UserLevel {
  id         String   @id @default(cuid())
  userId     String   @unique
  totalXP    Int      @default(0)
  level      String   @default("Apprentice")
  nextLevel  String?
  xpToNext   Int?
  updatedAt  DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([level])
}
