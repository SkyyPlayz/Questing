generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WORKER
  POSTER
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
}

enum JobStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  VOIDED
  REFUNDED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum IncidentStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum DisputeOutcome {
  WORKER_FAVOR
  POSTER_FAVOR
  SPLIT
  DISMISSED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  passwordHash  String
  role          Role       @default(WORKER)
  status        UserStatus @default(PENDING_VERIFICATION)
  emailVerified DateTime?
  bio           String?
  phone         String?
  location      String?
  avatarUrl     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  postedJobs      Job[]            @relation("PosterJobs")
  applications    Application[]
  sessions        Session[]
  accounts        Account[]
  workerProfile   WorkerProfile?
  posterProfile   PosterProfile?
  ratingsGiven    Rating[]         @relation("RatingFrom")
  ratingsReceived Rating[]         @relation("RatingTo")
  competencyScore CompetencyScore?
  riskScore       RiskScore?
  incidents       SafetyIncident[] @relation("IncidentReporter")
  adminNotes      AdminNote[]
}

model WorkerProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  skills                String[]
  availability          String?
  hourlyRate            Float?
  idVerified            Boolean  @default(false)
  backgroundCheckStatus String   @default("PENDING")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt             DateTime @updatedAt
}

model PosterProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String?
  bio         String?
  website     String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id           String         @id @default(cuid())
  title        String
  description  String
  category     String
  location     String
  payRate      Float
  payUnit      String         @default("hour")
  startDate    DateTime?
  endDate      DateTime?
  status       JobStatus      @default(DRAFT)
  posterId     String
  poster       User           @relation("PosterJobs", fields: [posterId], references: [id])
  applications Application[]
  payment      Payment?
  ratings      Rating[]
  disputes     Dispute[]
  incidents    SafetyIncident[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Application {
  id        String            @id @default(cuid())
  jobId     String
  workerId  String
  message   String?
  status    ApplicationStatus @default(PENDING)
  job       Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker    User              @relation(fields: [workerId], references: [id])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([jobId, workerId])
}

model Payment {
  id                      String        @id @default(cuid())
  jobId                   String        @unique
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  amount                  Int
  currency                String        @default("usd")
  status                  PaymentStatus @default(PENDING)
  job                     Job           @relation(fields: [jobId], references: [id])
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model Rating {
  id         String   @id @default(cuid())
  jobId      String
  fromUserId String
  toUserId   String
  score      Int
  comment    String?
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fromUser   User     @relation("RatingFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("RatingTo", fields: [toUserId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([jobId, fromUserId])
}

model CompetencyScore {
  id            String   @id @default(cuid())
  userId        String   @unique
  avgRating     Float    @default(0)
  jobsCompleted Int      @default(0)
  reliabilityPct Float   @default(0)
  overallScore  Float    @default(0)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt     DateTime @updatedAt
}

model SafetyIncident {
  id          String         @id @default(cuid())
  jobId       String
  reporterId  String
  severity    String
  description String
  status      IncidentStatus @default(OPEN)
  resolution  String?
  riskLevel   RiskLevel?
  job         Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reporter    User           @relation("IncidentReporter", fields: [reporterId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model RiskScore {
  id            String    @id @default(cuid())
  userId        String    @unique
  riskLevel     RiskLevel @default(LOW)
  incidentCount Int       @default(0)
  overrideNote  String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt     DateTime  @updatedAt
}

model Dispute {
  id         String          @id @default(cuid())
  jobId      String
  raisedById String
  status     DisputeStatus   @default(OPEN)
  outcome    DisputeOutcome?
  adminNote  String?
  job        Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  note      String
  authorId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
