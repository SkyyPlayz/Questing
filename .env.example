# Copy to .env and fill in real values locally. NEVER commit a real .env.
# All values here are placeholders — no real secrets belong in this file.

# ─── Database (required) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/questing

# ─── Auth (NextAuth) ─────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
AUTH_SECRET=replace-with-a-long-random-string

# ─── Payments (Stripe) — optional in dev; client initializes lazily ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (Resend) — optional; email is a no-op when unset ──────────
RESEND_API_KEY=
RESEND_FROM=noreply@questing.app

# ─── Safety escalation (see docs/planning/safety-escalation-plan.md) ─
# Default is the safest mode. Do NOT enable live dispatch outside a
# coordinated, scheduled test with the relevant authorities.
SAFETY_ESCALATION_MODE=simulate
SAFETY_LIVE_DISPATCH_ENABLED=false
